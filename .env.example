# Slated environment variables
# Copy this file to .env and fill in your own Supabase project values.
# These are read by Vite at build time (VITE_ prefix required for client-side access).
#
# The Supabase "publishable key" is the project's anon/public key — designed
# to be exposed in client code; RLS policies enforce access control.

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
